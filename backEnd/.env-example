# ============================================================
# SERVIDOR
# ============================================================
# Puerto donde escucha el backend (por defecto 3000)
PORT=3000

# Clave secreta para firmar y verificar los tokens JWT de autenticación.
# Usa una cadena larga y aleatoria. Nunca la compartas públicamente.
JWT_SECRET=tu_clave_secreta_para_tokens

# URLs del frontend permitidas por CORS (separadas por coma).
# En desarrollo suele ser http://localhost:5173
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Entorno de ejecución: "development" o "production"
NODE_ENV=development

# ============================================================
# BASE DE DATOS (MongoDB Atlas)
# ============================================================
# Cadena de conexión a MongoDB Atlas.
# Reemplaza usuario, password, cluster y nombre_db con tus datos.
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db

# ============================================================
# GOOGLE DRIVE — OAuth2  (3 variables obligatorias)
# ============================================================
# Estas credenciales permiten al sistema subir los certificados
# generados a Google Drive de forma automática.
#
# ── Paso 1: Crear credenciales en Google Cloud Console ──
#   1. Ve a https://console.cloud.google.com
#   2. Crea un proyecto (o selecciona uno existente).
#   3. Habilita la API de Google Drive.
#   4. Ve a "APIs y Servicios" → "Credenciales" → "Crear credenciales"
#      → "ID de cliente OAuth 2.0".
#   5. Tipo de aplicación: "App de escritorio".
#   6. Copia el Client ID y el Client Secret aquí:
GOOGLE_OAUTH_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-tu_client_secret

# ── Paso 2: Generar el Refresh Token ──
#   1. Ejecuta en la terminal:  node utils/setupDriveAuth.js
#   2. Se abrirá una ventana del navegador para autorizar con tu cuenta de Google.
#   3. Al completar la autorización, el script imprimirá el refresh token.
#   4. Pégalo aquí:
GOOGLE_OAUTH_REFRESH_TOKEN=1//tu_refresh_token_generado

# ── Paso 3: Carpeta raíz en Google Drive ──
# ID de la carpeta de Drive donde se almacenarán los certificados.
# Puedes obtenerlo de la URL de la carpeta en Drive:
#   https://drive.google.com/drive/folders/ESTE_ES_EL_ID
# Si se deja vacío, el sistema creará una carpeta nueva automáticamente.
GOOGLE_DRIVE_FOLDER_ID=

# ============================================================
# 2CAPTCHA (Resolución automática de captchas)
# ============================================================
# API Key del servicio 2Captcha, necesaria para que los scrapers
# resuelvan los captchas de las plataformas automáticamente.
# Regístrate en https://2captcha.com y copia tu API Key aquí:
TWOCAPTCHA_API_KEY=tu_api_key_de_2captcha
